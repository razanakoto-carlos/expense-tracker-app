{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",        // ← ESM natif
    "moduleResolution": "bundler", // ← résolution moderne
    "esModuleInterop": true,
    "types":["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  }
}
